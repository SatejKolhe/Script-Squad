PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173

# ── Email Notifications ────────────────────────────────────────────────────────
# Gmail address used to send reminders
EMAIL_USER=your-gmail@gmail.com
# Gmail App Password (NOT your real password)
# Get one at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-app-password-here
# Display name for outgoing emails
EMAIL_FROM=Script Squad <your-gmail@gmail.com>
# How many hours before deadline to send the reminder (default: 24)
DEADLINE_REMINDER_HOURS=24
# Cron schedule for the reminder job (default: every hour)
# Format: minute hour day month weekday
DEADLINE_CRON_SCHEDULE=0 * * * *

# ── AI (Google Gemini) ─────────────────────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
